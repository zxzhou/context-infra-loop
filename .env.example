# .env.example - required environment variables
# Copy this file to .env and fill in your own values.

# Gmail, used by send_email and crontab_monitor alert email
GMAIL_USERNAME=
GMAIL_APP_PASSWORD=

# OpenCode Server, used by observer, reflector, newsletter, and crontab_monitor
OPENCODE_API_URL=

# Google Analytics 4, used by ga4_metrics.py
GA4_PROPERTY_ID=
GA4_CREDENTIALS_JSON=

# Kit / ConvertKit, used by kit_metrics.py and newsletter publishing
KIT_API_KEY=

# Typefully posting
TYPEFULLY_API_KEY=

# Typefully metrics, captured from the browser
TYPEFULLY_COOKIES=

# Gemini, used for image generation
GEMINI_API_KEY=

# Optional Google-compatible variables for Gemini
GOOGLE_API_KEY=

# Optional image generation model override
IMAGE_MODEL=

# OpenAI-compatible embedding service, used by semantic_search
OPENAI_API_KEY=

# Tavily, used for web search and URL extraction
TAVILY_API_KEY=
